<div class="grid-row margin-top-7">
  <div class="grid-column-two-thirds-from-laptop">
    <h1>
      We’ve added your signature to the petition:
    </h1>

    <p class="margin-bottom-7">
      <%= link_to @petition.action, petition_path(@petition) %>
    </p>

    <hr>

    <% if @constituencies.any? %>
      <section class="margin-bottom-8">
        <h2>
          Contact your MP
        </h2>

        <% if @constituencies.many? %>
          <p>Your postcode <q><%= @signature.formatted_postcode %></q> matches more than one constituency:</p>
        <% else %>
          <p>Your constituency is:</p>
        <% end %>

        <ul class="margin-top-7">
          <% @constituencies.each do |constituency| %>
            <li class="margin-bottom-7">
              <h3>
                <%= constituency.name %>
              </h3>

              <% if constituency.mp_id? %>
                <p class="margin-bottom-2">
                  <strong><%= constituency.mp_name %></strong><br>
                  <%= constituency.party %>
                </p>

                <p>
                  <%= link_to constituency.mp_url, rel: "external" do %>
                    Let them know you have signed this petition
                  <% end %>
                </p>
              <% else %>
                <p>Seat is currently vacant pending a by-election</p>
              <% end %>
            </li>
          <% end %>
        </ul>
      </section>

      <hr>
    <% end %>

    <section>
      <h2>
        Register to vote
      </h2>

      <p>
        To vote in local and national elections, you must be registered to vote.
      </p>

      <p>
        It takes less than 5 minutes.
      </p>

      <p>
        <a href="https://www.gov.uk/register-to-vote" rel="external">Register to vote</a>
      </p>
    </section>
  </div>
</div>
