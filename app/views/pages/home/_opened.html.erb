<% content_for :hero_banner do %>
  <% if Site.show_home_page_message? %>
    <div class="highlight">
      <%= markdown_to_html(Site.home_page_message) %>
    </div>
  <% end %>

  <h1>
    Find, sign and create petitions
  </h1>

  <%= render "pages/home/search_petitions", search_path: petitions_path %>
<% end %>

<%= render "pages/home/start_petition" %>

<hr>

<% if no_petitions_yet? %>
  <section class="petition-items">
    <h2>The Petitions service is open</h2>
    <p>No petitions have been published yet – please check back later</p>
  </section>
<% else %>
  <%= render "pages/home/trending_petitions" %>
  <%= render "pages/home/explanation_petitions" %>
<% end %>
