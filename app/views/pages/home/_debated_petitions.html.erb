<% if actioned[:awaiting_debate][:count].zero? && actioned[:debated][:count].zero? %>
  <p>Parliament hasn’t debated any petitions yet</p>
<% else %>
  <ul>
    <% actioned[:with_debated_outcome][:list].each.with_index do |petition, index| %>
      <li class="petition-item">
        <h3>
          <%= link_to petition.action, petition_path(petition, anchor: 'debate') %>
        </h3>

        <div class="wrapper">
          <p>
            This topic was debated on <%= short_date_format petition.debate_outcome.debated_on %>
          </p>

          <p>
            <%= debate_outcome_image(petition.debate_outcome, loading: "lazy", alt: nil, aria: { hidden: true }) %>
          </p>

          <hr>

          <% if petition.debate_outcome.video_url.present? %>
            <p>
              <%= link_to video_service(petition.debate_outcome.video_url), rel: "external" do %>
                Watch the debate
                <span class="visually-hidden">for the ‘<%= petition.action %>’ petition</span>
                on <%= video_service(petition.debate_outcome.video_url) %>
              <% end %>
            </p>
          <% end %>

          <% if petition.debate_outcome.transcript_url.present? %>
            <p>
              <%= link_to petition.debate_outcome.transcript_url, rel: "external" do %>
                Read the transcript
                <span class="visually-hidden">for the ‘<%= petition.action %>’ petition</span>
                at parliament.uk
              <% end %>
            </p>
          <% end %>

          <% if petition.debate_outcome.debate_pack_url.present? %>
            <p>
              <%= link_to petition.debate_outcome.debate_pack_url, rel: "external" do %>
                Read the research
                <span class="visually-hidden">for the ‘<%= petition.action %>’ petition</span>
                at parliament.uk
              <% end %>
            </p>
          <% end %>

          <% if petition.debate_outcome.public_engagement_url.present? %>
            <p>
              <%= link_to petition.debate_outcome.public_engagement_url, rel: "external" do %>
                Read what the public said
                <span class="visually-hidden">about the ‘<%= petition.action %>’ petition</span>
                at parliament.uk
              <% end %>
            </p>
          <% end %>

          <% if petition.debate_outcome.debate_summary_url.present? %>
            <p>
              <%= link_to petition.debate_outcome.debate_summary_url, rel: "external" do %>
                Read a summary of the debate
                <span class="visually-hidden">for the ‘<%= petition.action %>’ petition</span>
                at parliament.uk
              <% end %>
            </p>
          <% end %>

          <p class="signature-count">
            <%= signature_count(:popular, petition.signature_count) %>
          </p>
        </div>
      </li>
    <% end %>
  </ul>
<% end %>
