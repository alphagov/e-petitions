<!DOCTYPE html>
<html lang="en-GB">
  <head>
    <title>
      <%= form_error? ? "Error: #{page_title}" : page_title %>
    </title>

    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">

    <%= preload_link_tag 'application.css', nopush: true %>
    <%= preload_link_tag 'application.js', nopush: true %>

    <% if Site.enable_analytics? %>
      <%= preload_link_tag 'cookie-manager.js', nopush: true %>
    <% end %>

    <%= preload_link_tag 'National-LFS-Book.woff2', nopush: true %>
    <%= preload_link_tag 'National-LFS-Semibold.woff2', nopush: true %>

    <%= stylesheet_link_tag 'application' %>

    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%= render 'application/os' %>
    <%= render 'application/social_meta' %>
    <% if noindex_page? %>
      <meta name="robots" content="noindex">
    <% end %>
    <meta name="theme-color" content="#373151">

    <% if Site.enable_analytics? %>
      <%= render 'application/gtm/tag' %>
    <% end %>
  </head>

  <body>
    <% if Site.enable_analytics? %>
      <%= render 'application/gtm/ns' %>
    <% end %>

    <%= render 'application/header' %>
    <%= render 'application/menu' %>

    <main id="main-content">
      <% if content_for?(:hero_banner) %>
        <header id="hero-banner">
          <div class="container">
            <%= yield :hero_banner %>
          </div>
        </header>
      <% end %>

      <div class="container">
        <%= yield :notifications %>
        <%= yield %>
      </div>
    </main>

    <%= render 'application/footer' %>

    <% if Site.enable_analytics? %>
      <%= render 'application/cookie_banner' %>
      <%= render 'application/cookie_preferences' %>

      <%= javascript_include_tag 'cookie-manager' %>
    <% end %>

    <%= javascript_include_tag 'application' %>

    <% if open_petition_page? %>
      <%= javascript_include_tag 'sharing' %>
    <% end %>
  </body>
</html>
